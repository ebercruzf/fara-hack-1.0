# ───────────────────────────────────────────────────────────────────
# Fara-Hack 1.0 — Environment Configuration
# Copy this file to .env and fill in the values.
# ───────────────────────────────────────────────────────────────────

# ===================================================================
# REQUIRED — server configuration
# ===================================================================

# HTTP/WebSocket port exposed by the fara-hack container.
HACK_HTTP_PORT=8080

# Auth token for the plugin WebSocket bridge (/api/bus).
# CHANGE THIS in any non-demo deployment.
FARARONI_PLUGIN_TOKEN=demo-token-change-me

# ===================================================================
# REQUIRED — Multimodal LLM (Ollama local — recommended)
# ===================================================================
# These three variables drive BOTH paths of the triage pipeline:
#
#   1. The Vision Adapter (LlmTriageClient) for the multimodal step:
#      hits /v1/chat/completions on the same Ollama instance.
#   2. The fararoni-core HiveMind for the reasoning step:
#      hits /api/chat via the OllamaProvider.
#
# When running inside Docker on macOS/Windows, host.docker.internal
# resolves to the host machine where Ollama is listening on :11434.
# On Linux, the docker-compose.yml maps it via extra_hosts.

# fararoni-core consumes these (LLM_SERVER_URL → /api/chat)
# NOTE: LLM_MODEL_NAME is the LEGACY v2-monorepo variable name. The
# public fararoni-core 1.0.0 jar (Apache 2.0, from fararoni-ecosystem
# GitHub) IGNORES it. See FARARONI_*_MODEL section below for the
# variables the public jar actually reads.
LLM_SERVER_URL=http://host.docker.internal:11434
LLM_MODEL_NAME=qwen3.5:35b-a3b
LLM_API_KEY=

# LlmTriageClient (vision adapter) consumes these (.../v1/chat/completions).
# These ARE used by the multimodal vision step (Step 0). Must point at
# a multimodal model — qwen3.5:35b-a3b is the only multimodal model
# pulled in the demo Ollama install.
OPENAI_COMPAT_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_COMPAT_MODEL=qwen3.5:35b-a3b
OPENAI_COMPAT_API_KEY=

# ===================================================================
# OPTIONAL — fararoni-core public jar model overrides
# ===================================================================
# The public fararoni-core 1.0.0 jar (Apache 2.0) reads these env
# vars to pick which model to load for the agentic execution path
# (DirectAgentExecutor → FaraCoreLlmDispatcher → expertClient).
#
# DEFAULTS (compiled into the public jar AppDefaults.java):
#   FARARONI_AGENTIC_MODEL = "qwen2.5-coder:32b"
#   FARARONI_TURTLE_MODEL  = "qwen2.5-coder:32b"
#   FARARONI_RABBIT_MODEL  = "qwen2.5-coder:1.5b"
#
# WHY qwen2.5-coder:32b for the AGENTIC path (architecture decision):
#   * Dense (not MoE) — no thinking-mode-eats-all-tokens problem
#     that we hit with qwen3.5:35b-a3b on the vision step
#   * Coder-tuned — strict JSON output and function/tool-calling
#     fidelity, exactly what the 4 triage agents need
#   * family qwen2 — the most stable Qwen generation for tool use
#   * 32B parameters — multi-step reasoning capable
#
# WHY qwen3.5:35b-a3b stays on the VISION path:
#   * It's the only multimodal model pulled in the demo Ollama
#   * Vision needs image understanding, not strict JSON
#   * The thinking mode is acceptable for vision because we give it
#     max_tokens=8000 in LlmTriageClient.java (line 175)
#
# This split is INTENTIONAL — leave the FARARONI_*_MODEL vars empty
# to use the optimal defaults. Override only if you have a different
# Ollama setup or want to test with a different model.
FARARONI_AGENTIC_MODEL=
FARARONI_TURTLE_MODEL=
FARARONI_RABBIT_MODEL=

# ===================================================================
# OPTIONAL — Cloud LLM via OpenRouter (alternative to Ollama)
# ===================================================================
# Replace the LLM_* and OPENAI_COMPAT_* vars above with these values
# if you prefer cloud inference. Get a key at https://openrouter.ai
#
#   LLM_SERVER_URL=https://openrouter.ai/api/v1
#   LLM_MODEL_NAME=anthropic/claude-3-haiku
#   LLM_API_KEY=sk-or-v1-...
#   OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_COMPAT_MODEL=anthropic/claude-3-haiku
#   OPENAI_COMPAT_API_KEY=sk-or-v1-...

# ===================================================================
# OPTIONAL — Multimodal mitigation step
# ===================================================================
# When true, after the LLM triages the bug, the SentinelDiffAdapter
# audits the patch suggestion and attaches it to the ticket if safe.
MITIGATION_PROPOSAL_ENABLED=true

# ===================================================================
# REQUIRED for email notifications — Mail (SMTP + IMAP) credentials
# ===================================================================
# These variables drive the `email_send`, `email_fetch`, and `email_read`
# tools used by the standalone `triage-agent.yaml` (loaded from
# workspace/.fararoni/config/agentes/triage-agent.yaml). They are read
# by fararoni-core's `EmailTransportService` via `ConfigPriorityResolver`
# (priority: ENV → SecureConfigService → file).
#
# Mapping (defined in fararoni-core/.../cli/ConfigCommand.java:178-225):
#   /config set mail-host        ←→ MAIL_HOST
#   /config set mail-port        ←→ MAIL_PORT
#   /config set mail-username    ←→ MAIL_USERNAME
#   /config set mail-password    ←→ MAIL_PASSWORD
#   /config set mail-imap-host   ←→ MAIL_IMAP_HOST
#   /config set mail-imap-port   ←→ MAIL_IMAP_PORT
#   /config set mail-sender      ←→ MAIL_SENDER
#   /config set mail-sender-name ←→ MAIL_SENDER_NAME
#
# Gmail setup:
#   1. Enable 2FA on the sending account.
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Paste the 16-char app password (with spaces) into MAIL_PASSWORD.
#   4. Use smtp.gmail.com:587 (STARTTLS) and imap.gmail.com:993 (SSL).
#
# Other providers (Outlook, Mailtrap, etc.) work the same way — just
# point MAIL_HOST and MAIL_IMAP_HOST at their server addresses.
#
# IMPORTANT: real credentials MUST live in `.env` (gitignored), NEVER
# in `.env.example`. The values below are placeholders.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_IMAP_HOST=imap.gmail.com
MAIL_IMAP_PORT=993
MAIL_SENDER=
MAIL_SENDER_NAME=fara-agent

# ===================================================================
# OPTIONAL — On-call engineer recipient
# ===================================================================
# Email address that the Triage Broker agent
# (workspace/.fararoni/config/agentes/triage-broker-agent.yaml) uses as
# the destination for P0/P1 notifications. If unset, the controller
# falls back to the reporter's email so the demo still produces a
# working end-to-end loop with zero operator-specific configuration.
ONCALL_EMAIL=

# ===================================================================
# OPTIONAL — eShop bind mount (for the Code Surgeon agent)
# ===================================================================
# Path on the host pointing to the e-commerce repo (Microsoft eShop
# .NET or any subset). Mounted read-only at /repo inside the container.
ESHOP_REPO_PATH=./mock-eshop

# ===================================================================
# OPTIONAL — Logging
# ===================================================================
LOG_LEVEL=INFO

# ===================================================================
# OPTIONAL — Hackathon submission metadata
# ===================================================================
HACK_TEAM_NAME=Fararoni
HACK_SUBMISSION_TAG=AgentXHackathon
